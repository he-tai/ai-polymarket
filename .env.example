# 复制为 .env 后填写。不要提交 .env。

# --- 实盘交易配置（CLOB L1/L2，基于 py-clob-client） ---
PRIVATE_KEY=
# 在 Polymarket 设置页可见的个人资料/代理钱包地址（funder 持有资金）。
FUNDER_ADDRESS=
# 0 = EOA, 1 = Magic 代理, 2 = Gnosis Safe（polymarket.com 用户常用）
SIGNATURE_TYPE=2

# --- DeepSeek AI 分析 ---
DEEPSEEK_API_KEY=
# 可选，默认 deepseek-chat
DEEPSEEK_MODEL=deepseek-reasoner
# 可选，默认 https://api.deepseek.com
DEEPSEEK_BASE_URL=https://api.deepseek.com

# --- 存储配置（SQLite 或 Postgres） ---
# SQLite 示例：
DATABASE_URL=sqlite:///trading.db
# Postgres 示例：
# DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/ai_polymarket

# --- Docker 自动交易循环参数 ---
# true=真实下单，false=仅分析不下单
AUTO_LIVE_MODE=false
AUTO_TOP_MARKETS=10
AUTO_MAX_ORDERS=1
AUTO_MIN_CONFIDENCE=0.8
AUTO_DEFAULT_SIZE=5
AUTO_ANALYSIS_TIMEOUT_S=45
AUTO_INTERVAL_SECONDS=60
AUTO_SIGNATURE_TYPE=1
RUNTIME_CONFIG_PATH=config/runtime_config.json
